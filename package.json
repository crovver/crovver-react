{
  "name": "crovver-react",
  "version": "1.1.0",
  "description": "React SDK for Crovver",
  "author": "Crovver <engineering@crovver.com>",
  "license": "MIT",
  "homepage": "https://github.com/crovver/react-sdk#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/crovver/react-sdk.git"
  },
  "bugs": {
    "url": "https://github.com/crovver/react-sdk/issues"
  },
  "keywords": [
    "crovver",
    "react",
    "subscription",
    "billing",
    "paywall",
    "saas",
    "feature-flags",
    "stripe",
    "payment"
  ],
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "dependencies": {},
  "devDependencies": {
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@types/node": "^20.10.5",
    "typescript": "^5.3.3",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "tsup": "^8.0.1"
  },
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "type-check": "tsc --noEmit",
    "clean": "rm -rf dist",
    "prepublishOnly": "pnpm run clean && pnpm run build"
  }
}
